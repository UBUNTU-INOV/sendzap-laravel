{
    "name": "sendzap/laravel-sdk",
    "description": "A Laravel SDK to interact with the SendZap WhatsApp API.",
    "keywords": ["laravel", "sendzap", "whatsapp", "sdk"],
    "homepage": "https://github.com/UBUNTU-CENTER/sendzap-laravel",
    "support": {
        "issues": "https://github.com/UBUNTU-CENTER/sendzap-laravel/issues",
        "source": "https://github.com/UBUNTU-CENTER/sendzap-laravel"
    },
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "SendZap Team",
            "email": "support@sendzap.click"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Sendzap\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sendzap\\Laravel\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Sendzap\\Laravel\\SendzapServiceProvider"
            ],
            "aliases": {
                "Sendzap": "Sendzap\\Laravel\\Facades\\Sendzap"
            }
        }
    }
}
